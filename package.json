{
  "name": "luxcss",
  "version": "2.0.0",
  "description": "Attribute-first CSS & JS library. Style anything with one HTML attribute. Zero dependencies, no build step.",
  "main": "dist/lux.js",
  "style": "dist/lux.css",
  "types": "dist/lux.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "css",
    "javascript",
    "css-library",
    "frontend",
    "ui",
    "design-system",
    "zero-dependency",
    "attributes",
    "html",
    "styling",
    "nextjs",
    "react"
  ],
  "author": "Abideen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abideen-program/luxcss.git"
  },
  "homepage": "https://abideen-program.github.io/luxcss/",
  "bugs": {
    "url": "https://github.com/Abideen-program/luxcss/issues"
  },
  "scripts": {
    "build": "echo 'No build step needed — dist/ is the source'",
    "prepublishOnly": "npm run build"
  },
  "unpkg": "dist/lux.js",
  "jsdelivr": "dist/lux.js",
  "exports": {
    ".": {
      "style": "./dist/lux.css",
      "browser": "./dist/lux.js",
      "default": "./dist/lux.js"
    },
    "./css": "./dist/lux.css",
    "./dist/lux.css": "./dist/lux.css",
    "./dist/lux.js": "./dist/lux.js",
    "./dist/lux.d.ts": "./dist/lux.d.ts"
  },
  "sideEffects": [
    "dist/lux.css",
    "dist/lux.js"
  ]
}
